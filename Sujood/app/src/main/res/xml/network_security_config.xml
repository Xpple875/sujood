<?xml version="1.0" encoding="utf-8"?>
<!--
    Enforces HTTPS-only for all connections app-wide.
    Cleartext (HTTP) traffic is blocked everywhere.

    Certificate pinning for api.aladhan.com is currently disabled.
    To re-enable, run this on your machine to get the real SHA-256 pin:
      openssl s_client -connect api.aladhan.com:443 2>/dev/null \
        | openssl x509 -pubkey -noout | openssl pkey -pubin -outform DER \
        | openssl dgst -sha256 -binary | base64
    Then add a <domain-config> block with <pin-set> below.
-->
<network-security-config>

    <!-- Block all cleartext (HTTP) traffic app-wide -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
