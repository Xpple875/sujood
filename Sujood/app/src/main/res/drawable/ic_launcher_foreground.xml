<?xml version="1.0" encoding="utf-8"?>
<!-- Sujood app icon foreground: white onion dome + crescent on teal bg -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Onion dome shape: starts wide at base (y=76), curves in,
        then bulges out (the "onion" belly), tapers to a thin neck,
        then ends at a pointed finial tip (y=28).
        Drawn as a single filled path.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M54,28
            C54,28 52,30 51,32
            C50,34 51,36 54,38
            C57,36 58,34 57,32
            C56,30 54,28 54,28 Z

            M54,38
            C50,38 44,42 40,50
            C36,58 35,64 35,68
            C35,70 36,72 38,73
            L70,73
            C72,72 73,70 73,68
            C73,64 72,58 68,50
            C64,42 58,38 54,38 Z
        "/>

    <!-- Crescent moon above the finial -->
    <!-- Outer circle of crescent -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,18 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0"/>
    <!-- Inner cutout to form crescent (background colour = #0D2233) -->
    <path
        android:fillColor="#0D2233"
        android:pathData="M56.5,16 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0"/>

</vector>
